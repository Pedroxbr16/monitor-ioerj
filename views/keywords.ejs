<%- include('partials/head', { title: 'Monitoramentos' }) %>
<body>
<%- include('partials/sidebar', { page: 'keywords' }) %>

<div class="main-content">
  <div class="top-bar">
    <div>
      <h5 class="mb-0 fw-600">Monitoramentos</h5>
      <small class="text-muted">Combine secoes e palavras-chave para monitorar o DOERJ</small>
    </div>
    <button class="btn btn-primary btn-sm ms-auto" id="btnAdicionar">
      <i class="bi bi-plus-lg me-1"></i> Novo monitoramento
    </button>
  </div>

  <div class="page-content">
    <div class="alert alert-info d-flex align-items-start gap-2">
      <i class="bi bi-bell-fill mt-1"></i>
      <div>
        No primeiro scan, o sistema apenas marca o que ja existe como visto.
        Os alertas sao disparados somente para publicacoes novas que aparecerem depois disso.
      </div>
    </div>

    <div class="card">
      <div class="card-body p-0">
        <% if (!keywords.length) { %>
          <div class="empty-state">
            <i class="bi bi-key"></i>
            <p>Voce ainda nao tem monitoramentos cadastrados.</p>
            <button class="btn btn-primary btn-sm" id="btnAdicionarEmpty">
              <i class="bi bi-plus-lg me-1"></i> Adicionar agora
            </button>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Palavra ou frase</th>
                  <th>Escopo</th>
                  <th>Canais</th>
                  <th>Status</th>
                  <th>Ultimo scan</th>
                  <th>IDs monitorados</th>
                  <th class="text-end">Acoes</th>
                </tr>
              </thead>
              <tbody>
                <% keywords.forEach(kw => { %>
                  <% const encodedRule = encodeURIComponent(JSON.stringify({
                    id: kw._id,
                    text: kw.text || '',
                    sections: kw.sections || [],
                    emailEnabled: kw.emailEnabled,
                    whatsappEnabled: kw.whatsappEnabled
                  })); %>
                  <% const scopeText = describeSectionScope(kw.sections, { compact: true }); %>
                  <% const ruleLabel = describeMonitorRule(kw, { compact: true }); %>
                  <tr id="row-<%= kw._id %>">
                    <td>
                      <% if (kw.text) { %>
                        <div class="fw-500"><%= kw.text %></div>
                        <div class="text-muted small">Filtro por palavra ou frase dentro do escopo.</div>
                      <% } else { %>
                        <div class="fw-500">Todas as publicacoes do escopo</div>
                        <div class="text-muted small">Sem palavra especifica.</div>
                      <% } %>
                    </td>
                    <td>
                      <span class="badge <%= kw.sections && kw.sections.length ? 'bg-secondary-soft text-secondary' : 'bg-primary-soft text-primary' %>"><%= scopeText %></span>
                      <% if (kw.sections && kw.sections.length > 1) { %>
                        <div class="text-muted small mt-1"><%= kw.sections.length %> secoes selecionadas</div>
                      <% } %>
                    </td>
                    <td>
                      <% if (kw.emailEnabled) { %>
                        <span class="badge bg-info-soft text-info me-1"><i class="bi bi-envelope-fill me-1"></i>Email</span>
                      <% } %>
                      <% if (kw.whatsappEnabled) { %>
                        <span class="badge bg-success-soft text-success"><i class="bi bi-whatsapp me-1"></i>WhatsApp</span>
                      <% } %>
                      <% if (!kw.emailEnabled && !kw.whatsappEnabled) { %>
                        <span class="text-muted" style="font-size:0.8rem">Nenhum</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="status-badge <%= kw.active ? 'status-active' : 'status-inactive' %>" id="status-<%= kw._id %>">
                        <i class="bi bi-circle-fill me-1" style="font-size:8px"></i>
                        <%= kw.active ? 'Ativo' : 'Pausado' %>
                      </span>
                    </td>
                    <td>
                      <% if (kw.lastChecked) { %>
                        <span style="font-size:0.85rem;color:#64748b"><%= new Date(kw.lastChecked).toLocaleString('pt-BR') %></span>
                      <% } else if (!kw.firstScanDone) { %>
                        <span class="badge bg-warning-soft text-warning">Aguardando 1o scan</span>
                      <% } else { %>
                        <span class="text-muted" style="font-size:0.85rem">-</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="badge bg-secondary-soft text-secondary"><%= kw.seenIds.length %> IDs</span>
                    </td>
                    <td class="text-end">
                      <div class="d-flex gap-2 justify-content-end">
                        <button
                          class="btn btn-sm btn-outline-secondary"
                          data-rule="<%= encodedRule %>"
                          onclick="editarKeyword(this)"
                          title="Editar"
                        >
                          <i class="bi bi-pencil"></i>
                        </button>
                        <button
                          class="btn btn-sm <%= kw.active ? 'btn-outline-warning' : 'btn-outline-success' %>"
                          id="btnToggle-<%= kw._id %>"
                          onclick="toggleKeyword('<%= kw._id %>')"
                          title="<%= kw.active ? 'Pausar' : 'Ativar' %>"
                        >
                          <i class="bi bi-<%= kw.active ? 'pause-fill' : 'play-fill' %>"></i>
                        </button>
                        <button
                          class="btn btn-sm btn-outline-danger"
                          data-id="<%= kw._id %>"
                          data-label="<%= ruleLabel %>"
                          onclick="deletarKeyword(this)"
                          title="Deletar"
                        >
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
<script>
const sectionOptions = <%- JSON.stringify(sectionOptions) %>;

function escapeHtml(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function renderSectionPicker(selectedSections = []) {
  const selected = Array.isArray(selectedSections) ? selectedSections : [];
  const allChecked = selected.length === 0;

  return `
    <div class="section-picker mt-2">
      <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="swal-all-sections" ${allChecked ? 'checked' : ''}>
        <label class="form-check-label fw-500" for="swal-all-sections">Todo o DOERJ</label>
      </div>
      <div class="section-checkbox-list ${allChecked ? 'is-disabled' : ''}" id="swal-sections-wrap">
        ${sectionOptions.map(option => `
          <label class="section-check">
            <input
              class="form-check-input swal-section-option"
              type="checkbox"
              value="${escapeHtml(option.id)}"
              ${selected.includes(option.id) ? 'checked' : ''}
              ${allChecked ? 'disabled' : ''}
            >
            <span>${escapeHtml(option.label)}</span>
          </label>
        `).join('')}
      </div>
      <div class="form-text mt-2">Marque uma ou mais secoes. Se "Todo o DOERJ" estiver ativo, as secoes especificas sao ignoradas.</div>
    </div>
  `;
}

function syncSectionPickerState(popup) {
  const allCheckbox = popup.querySelector('#swal-all-sections');
  const sectionInputs = [...popup.querySelectorAll('.swal-section-option')];
  const wrap = popup.querySelector('#swal-sections-wrap');

  if (allCheckbox.checked) {
    sectionInputs.forEach(input => {
      input.checked = false;
      input.disabled = true;
    });
    wrap.classList.add('is-disabled');
    return;
  }

  sectionInputs.forEach(input => { input.disabled = false; });
  wrap.classList.remove('is-disabled');
}

function bindSectionPickerEvents(popup) {
  const allCheckbox = popup.querySelector('#swal-all-sections');
  const sectionInputs = [...popup.querySelectorAll('.swal-section-option')];

  allCheckbox.addEventListener('change', () => syncSectionPickerState(popup));

  sectionInputs.forEach(input => {
    input.addEventListener('change', () => {
      const anyChecked = sectionInputs.some(item => item.checked);
      allCheckbox.checked = !anyChecked;
      syncSectionPickerState(popup);
    });
  });
}

function abrirModal(rule = {}) {
  const state = {
    id: rule.id || null,
    text: rule.text || '',
    sections: Array.isArray(rule.sections) ? rule.sections : [],
    emailEnabled: typeof rule.emailEnabled === 'boolean' ? rule.emailEnabled : true,
    whatsappEnabled: typeof rule.whatsappEnabled === 'boolean' ? rule.whatsappEnabled : false
  };

  Swal.fire({
    title: state.id ? 'Editar monitoramento' : 'Novo monitoramento',
    html: `
      <div class="text-start">
        <label class="form-label fw-500 mb-1">Palavra ou frase <span class="text-muted">(opcional se houver secao)</span></label>
        <input
          id="swal-text"
          class="swal2-input mt-0 mb-2"
          placeholder="Ex: contrato, auditoria, portaria..."
          value="${escapeHtml(state.text)}"
          style="margin:0;width:100%"
        >
        <div class="form-text mb-3">Se deixar em branco, o sistema monitora tudo que aparecer nas secoes escolhidas.</div>
        <label class="form-label fw-500 mb-1">Escopo do monitoramento</label>
        ${renderSectionPicker(state.sections)}
        <label class="form-label fw-500 mb-2 mt-3">Canais de alerta</label>
        <div class="d-flex gap-3">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="swal-email" ${state.emailEnabled ? 'checked' : ''}>
            <label class="form-check-label" for="swal-email"><i class="bi bi-envelope-fill text-info me-1"></i>Email</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="swal-zap" ${state.whatsappEnabled ? 'checked' : ''}>
            <label class="form-check-label" for="swal-zap"><i class="bi bi-whatsapp text-success me-1"></i>WhatsApp</label>
          </div>
        </div>
      </div>
    `,
    showCancelButton: true,
    confirmButtonText: state.id ? 'Salvar alteracoes' : '<i class="bi bi-plus-lg me-1"></i> Adicionar',
    cancelButtonText: 'Cancelar',
    confirmButtonColor: '#2563eb',
    focusConfirm: false,
    customClass: { popup: 'swal-wide' },
    didOpen: () => bindSectionPickerEvents(Swal.getPopup()),
    preConfirm: () => {
      const popup = Swal.getPopup();
      const text = popup.querySelector('#swal-text').value.trim();
      const allSelected = popup.querySelector('#swal-all-sections').checked;
      const sections = allSelected
        ? []
        : [...popup.querySelectorAll('.swal-section-option:checked')].map(input => input.value);

      if (!text && !sections.length) {
        Swal.showValidationMessage('Digite uma palavra-chave ou selecione ao menos uma secao especifica.');
        return false;
      }

      return {
        text,
        sections,
        emailEnabled: popup.querySelector('#swal-email').checked,
        whatsappEnabled: popup.querySelector('#swal-zap').checked
      };
    }
  }).then(async result => {
    if (!result.isConfirmed) return;

    const body = result.value;
    const method = state.id ? 'PUT' : 'POST';
    const url = state.id ? `/keywords/${state.id}` : '/keywords';

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });

    const data = await res.json();
    if (data.ok) {
      Swal.fire({
        icon: 'success',
        title: state.id ? 'Salvo!' : 'Adicionado!',
        text: state.id
          ? 'Monitoramento atualizado. O proximo ciclo vai rearmar a regra.'
          : 'Monitoramento criado. O primeiro ciclo apenas arma a regra para novas publicacoes.',
        timer: 2000,
        showConfirmButton: false
      });
      setTimeout(() => location.reload(), 1800);
    } else {
      Swal.fire({ icon: 'error', title: 'Erro', text: data.erro });
    }
  });
}

document.getElementById('btnAdicionar').addEventListener('click', () => abrirModal());
const btnEmpty = document.getElementById('btnAdicionarEmpty');
if (btnEmpty) btnEmpty.addEventListener('click', () => abrirModal());

function editarKeyword(button) {
  const rule = JSON.parse(decodeURIComponent(button.dataset.rule));
  abrirModal(rule);
}

async function toggleKeyword(id) {
  const res = await fetch(`/keywords/${id}/toggle`, { method: 'PATCH' });
  const data = await res.json();
  if (data.ok) {
    const badge = document.getElementById(`status-${id}`);
    const btn = document.getElementById(`btnToggle-${id}`);
    if (data.active) {
      badge.className = 'status-badge status-active';
      badge.innerHTML = '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i> Ativo';
      btn.className = 'btn btn-sm btn-outline-warning';
      btn.innerHTML = '<i class="bi bi-pause-fill"></i>';
      btn.title = 'Pausar';
    } else {
      badge.className = 'status-badge status-inactive';
      badge.innerHTML = '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i> Pausado';
      btn.className = 'btn btn-sm btn-outline-success';
      btn.innerHTML = '<i class="bi bi-play-fill"></i>';
      btn.title = 'Ativar';
    }
    const toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
    toast.fire({ icon: 'success', title: data.active ? 'Monitoramento ativado' : 'Monitoramento pausado' });
  }
}

function deletarKeyword(button) {
  const id = button.dataset.id;
  const label = button.dataset.label;

  Swal.fire({
    title: 'Deletar monitoramento?',
    html: `A regra <strong>"${escapeHtml(label)}"</strong> e todo o historico serao removidos.`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Sim, deletar',
    cancelButtonText: 'Cancelar',
    confirmButtonColor: '#dc3545'
  }).then(async result => {
    if (!result.isConfirmed) return;
    const res = await fetch(`/keywords/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.ok) {
      document.getElementById(`row-${id}`).remove();
      const toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
      toast.fire({ icon: 'success', title: 'Deletado com sucesso' });
    }
  });
}
</script>
