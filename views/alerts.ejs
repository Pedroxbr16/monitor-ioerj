<%- include('partials/head', { title: 'Alertas' }) %>
<body>
<%- include('partials/sidebar', { page: 'alerts' }) %>

<div class="main-content">
  <div class="top-bar">
    <div>
      <h5 class="mb-0 fw-600">Alertas</h5>
      <small class="text-muted">Historico de notificacoes enviadas</small>
    </div>
  </div>

  <div class="page-content">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-600"><i class="bi bi-bell-fill me-2 text-primary"></i>Todos os alertas</h6>
        <% if (alerts.length) { %>
          <span class="badge bg-primary"><%= alerts.length %> registros</span>
        <% } %>
      </div>
      <div class="card-body p-0">
        <% if (!alerts.length) { %>
          <div class="empty-state">
            <i class="bi bi-bell-slash"></i>
            <p>Nenhum alerta foi enviado ainda.</p>
            <a href="/keywords" class="btn btn-primary btn-sm">Configurar monitoramentos</a>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Monitoramento</th>
                  <th>Canal</th>
                  <th>Status</th>
                  <th>Data DO</th>
                  <th>ID Materia</th>
                  <th>Jornal</th>
                  <th>Resumo</th>
                  <th>Enviado em</th>
                  <th>Abrir</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% alerts.forEach(alert => { %>
                  <tr
                    id="alert-<%= alert._id %>"
                    class="clickable-row"
                    data-row-url="<%= alert.viewUrl %>"
                    tabindex="0"
                    title="Clique para abrir a leitura do alerta"
                  >
                    <td><span class="badge bg-primary-soft text-primary"><%= alert.keywordText %></span></td>
                    <td>
                      <% if (alert.channel === 'email') { %>
                        <span class="badge bg-info-soft text-info"><i class="bi bi-envelope-fill me-1"></i>Email</span>
                      <% } else { %>
                        <span class="badge bg-success-soft text-success"><i class="bi bi-whatsapp me-1"></i>WhatsApp</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (alert.status === 'sent') { %>
                        <span class="badge bg-success-soft text-success"><i class="bi bi-check-circle-fill me-1"></i>Enviado</span>
                      <% } else { %>
                        <span class="badge bg-danger-soft text-danger"><i class="bi bi-x-circle-fill me-1"></i>Falhou</span>
                      <% } %>
                    </td>
                    <td><%= alert.occurrence.dataPublicacao || '-' %></td>
                    <td>
                      <% if (alert.occurrence.sourceUrl) { %>
                        <a
                          href="<%= alert.occurrence.sourceUrl %>"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="fw-700 text-decoration-none"
                          data-row-ignore="true"
                        >
                          <%= alert.occurrence.idMateria || '-' %>
                        </a>
                      <% } else { %>
                        <strong><%= alert.occurrence.idMateria || '-' %></strong>
                      <% } %>
                    </td>
                    <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= alert.occurrence.jornal || '-' %></td>
                    <td style="max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= alert.occurrence.resumo %>"><%- alert.highlightedResumo || '-' %></td>
                    <td style="white-space:nowrap;font-size:0.82rem;color:#64748b"><%= new Date(alert.sentAt).toLocaleString('pt-BR') %></td>
                    <td>
                      <% if (alert.occurrence.sourceUrl) { %>
                        <a
                          href="<%= alert.occurrence.sourceUrl %>"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn btn-sm btn-outline-primary"
                          title="Abrir materia no DOERJ"
                          data-row-ignore="true"
                        >
                          <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                      <% } else { %>
                        <span class="text-muted small">-</span>
                      <% } %>
                    </td>
                    <td>
                      <button class="btn btn-sm btn-outline-danger" onclick="deletarAlerta('<%= alert._id %>')" title="Remover" data-row-ignore="true">
                        <i class="bi bi-trash"></i>
                      </button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
<script>
document.querySelectorAll('.clickable-row[data-row-url]').forEach(row => {
  function shouldIgnore(target) {
    return !!target.closest('a, button, [data-row-ignore="true"]');
  }

  row.addEventListener('click', event => {
    if (shouldIgnore(event.target)) return;
    window.location.href = row.dataset.rowUrl;
  });

  row.addEventListener('keydown', event => {
    if (event.key !== 'Enter' && event.key !== ' ') return;
    event.preventDefault();
    window.location.href = row.dataset.rowUrl;
  });
});

function deletarAlerta(id) {
  Swal.fire({
    title: 'Remover alerta?',
    text: 'Este registro sera removido do historico.',
    icon: 'question',
    showCancelButton: true,
    confirmButtonText: 'Sim, remover',
    cancelButtonText: 'Cancelar',
    confirmButtonColor: '#dc3545'
  }).then(async result => {
    if (!result.isConfirmed) return;
    const res = await fetch(`/alerts/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.ok) {
      document.getElementById(`alert-${id}`).remove();
      const toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 });
      toast.fire({ icon: 'success', title: 'Removido' });
    }
  });
}
</script>
