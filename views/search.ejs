<%- include('partials/head', { title: 'Busca Historica' }) %>
<body>
<%- include('partials/sidebar', { page: 'search' }) %>

<div class="main-content">
  <div class="top-bar">
    <div>
      <h5 class="mb-0 fw-600">Busca Historica</h5>
      <small class="text-muted">Pesquise publicacoes antigas por secao e palavra-chave</small>
    </div>
  </div>

  <div class="page-content">
    <div class="alert alert-info d-flex align-items-start gap-2">
      <i class="bi bi-info-circle-fill mt-1"></i>
      <div>
        Esta tela faz apenas busca historica. Ela nao cria alerta automaticamente.
        Para receber alertas, salve um monitoramento em <a href="/keywords" class="alert-link">Monitoramentos</a>.
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">
        <h6 class="mb-0 fw-600"><i class="bi bi-search me-2 text-primary"></i>Parametros da busca</h6>
      </div>
      <div class="card-body">
        <form action="/search" method="POST" id="formBusca">
          <div class="row g-3">
            <div class="col-lg-5">
              <label class="form-label">Palavra ou frase <span class="text-muted">(opcional se houver secao)</span></label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input
                  type="text"
                  name="keyword"
                  class="form-control"
                  placeholder="Ex: gestores do contrato, portaria, auditoria..."
                  value="<%= params.keyword || '' %>"
                />
              </div>
              <div class="form-text">Se voce escolher uma ou mais secoes, pode deixar esse campo em branco para ver tudo daquele escopo.</div>
            </div>
            <div class="col-md-3">
              <label class="form-label">Data inicio <span class="text-muted">(opcional)</span></label>
              <input type="date" name="dataInicio" class="form-control" value="<%= params.dataInicio || '' %>" />
            </div>
            <div class="col-md-3">
              <label class="form-label">Data fim <span class="text-muted">(opcional)</span></label>
              <input type="date" name="dataFim" class="form-control" value="<%= params.dataFim || '' %>" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100" id="btnBuscar">
                <i class="bi bi-search"></i>
              </button>
            </div>
            <div class="col-12">
              <label class="form-label">Secoes do Diario</label>
              <div class="section-picker">
                <div class="form-check mb-2">
                  <input class="form-check-input" type="checkbox" id="all-sections" <%= !params.sections.length ? 'checked' : '' %>>
                  <label class="form-check-label fw-500" for="all-sections">Todo o DOERJ</label>
                </div>
                <div class="section-checkbox-list <%= !params.sections.length ? 'is-disabled' : '' %>" id="section-options">
                  <% sectionOptions.forEach(option => { %>
                    <label class="section-check">
                      <input
                        class="form-check-input section-option"
                        type="checkbox"
                        name="sections"
                        value="<%= option.id %>"
                        <%= params.sections.includes(option.id) ? 'checked' : '' %>
                        <%= !params.sections.length ? 'disabled' : '' %>
                      >
                      <span><%= option.label %></span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text mt-2">Marque uma ou mais secoes. Se "Todo o DOERJ" estiver ativo, o filtro de secao e ignorado.</div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>

    <% if (erro) { %>
      <div class="alert alert-danger d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-circle-fill"></i> Erro ao buscar: <%= erro %>
      </div>
    <% } %>

    <% if (resultados !== null) { %>
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0 fw-600">
            <i class="bi bi-list-ul me-2 text-primary"></i>
            Resultados
            <% if (resultados.length) { %>
              <span class="badge bg-primary ms-1"><%= resultados.length %></span>
            <% } %>
          </h6>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="badge <%= params.sections.length ? 'bg-secondary-soft text-secondary' : 'bg-primary-soft text-primary' %>">
              <%= describeSectionScope(params.sections, { compact: true }) %>
            </span>
            <% if (params.keyword) { %>
              <span class="badge bg-primary-soft text-primary"><%= params.keyword %></span>
            <% } %>
            <% if (totalBruto > resultados.length) { %>
              <span class="badge bg-warning-soft text-warning" title="O IOERJ retornou <%= totalBruto %> resultados, mas apenas <%= resultados.length %> permaneceram apos os filtros locais.">
                <i class="bi bi-funnel-fill me-1"></i><%= totalBruto %> -> <%= resultados.length %>
              </span>
            <% } %>
          </div>
        </div>
        <div class="card-body p-0">
          <% if (!resultados.length) { %>
            <div class="empty-state">
              <i class="bi bi-file-earmark-x"></i>
              <p>Nenhuma publicacao encontrada para os criterios informados.</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Data</th>
                    <th>ID Materia</th>
                    <th>Pagina</th>
                    <th>Jornal</th>
                    <th>Tipo</th>
                    <th>Resumo</th>
                    <th>Abrir</th>
                  </tr>
                </thead>
                <tbody>
                  <% resultados.forEach((item, index) => { %>
                    <tr
                      class="clickable-row search-result-row"
                      tabindex="0"
                      title="Clique para abrir o resumo desta materia"
                      data-id="<%= item.idMateria || '-' %>"
                      data-data="<%= item.dataPublicacao || '-' %>"
                      data-pagina="<%= item.pagina || '-' %>"
                      data-jornal="<%= encodeURIComponent(item.jornal || '-') %>"
                      data-tipo="<%= encodeURIComponent(item.tipo || '-') %>"
                      data-resumo="<%= encodeURIComponent(item.resumo || '-') %>"
                      data-source-url="<%= encodeURIComponent(item.sourceUrl || '') %>"
                      data-viewer-url="<%= encodeURIComponent(item.archiveViewerUrl || '') %>"
                    >
                      <td><span class="badge bg-secondary-soft text-secondary"><%= item.dataPublicacao || '-' %></span></td>
                      <td><strong><%= item.idMateria || '-' %></strong></td>
                      <td><%= item.pagina || '-' %></td>
                      <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= item.jornal || '-' %></td>
                      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= item.tipo || '-' %></td>
                      <td style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= item.resumo %>"><%- item.highlightedResumo || '-' %></td>
                      <td>
                        <% if (item.archiveViewerUrl) { %>
                          <a
                            href="<%= item.archiveViewerUrl %>"
                            class="btn btn-sm btn-outline-warning me-1"
                            title="Abrir PDF local com marcador"
                            data-row-ignore="true"
                          >
                            <i class="bi bi-highlighter"></i>
                          </a>
                        <% } %>
                        <% if (item.sourceUrl) { %>
                          <a
                            href="<%= item.sourceUrl %>"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="btn btn-sm btn-outline-primary"
                            title="Abrir materia no DOERJ"
                            data-row-ignore="true"
                          >
                            <i class="bi bi-box-arrow-up-right"></i>
                          </a>
                        <% } else { %>
                          <span class="text-muted small">-</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<div class="modal fade" id="searchResultModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-1">Resumo da materia</h5>
          <small class="text-muted">Clique no botao azul para abrir o DOERJ oficial</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <div class="alert-meta-grid mb-4">
          <div>
            <small class="text-muted d-block">Data do DO</small>
            <strong id="search-modal-data">-</strong>
          </div>
          <div>
            <small class="text-muted d-block">ID da materia</small>
            <strong id="search-modal-id">-</strong>
          </div>
          <div>
            <small class="text-muted d-block">Pagina</small>
            <strong id="search-modal-pagina">-</strong>
          </div>
          <div>
            <small class="text-muted d-block">Jornal</small>
            <strong id="search-modal-jornal">-</strong>
          </div>
        </div>

        <div class="mb-3">
          <small class="text-muted d-block">Tipo</small>
          <strong id="search-modal-tipo">-</strong>
        </div>

        <% if (highlightTerms.length) { %>
          <div class="mb-3">
            <small class="text-muted d-block mb-2">Destaques aplicados</small>
            <div class="d-flex flex-wrap gap-2">
              <% highlightTerms.forEach(term => { %>
                <span class="badge bg-warning-soft text-warning border border-warning-subtle"><%= term %></span>
              <% }) %>
            </div>
          </div>
        <% } %>

        <% if (ignoredShortKeyword) { %>
          <div class="alert alert-warning">
            O termo "<strong><%= ignoredShortKeyword %></strong>" e muito curto para destacar sem pintar o texto inteiro.
            Por isso, destaquei a secao monitorada.
          </div>
        <% } %>

        <div>
          <small class="text-muted d-block mb-2">Resumo encontrado</small>
          <div class="highlighted-reading" id="search-modal-resumo">-</div>
        </div>
      </div>
      <div class="modal-footer">
        <a href="#" class="btn btn-warning disabled" id="search-modal-viewer">
          <i class="bi bi-highlighter me-1"></i>Marcar no PDF
        </a>
        <a href="#" class="btn btn-outline-secondary disabled" id="search-modal-open" target="_blank" rel="noopener noreferrer">
          <i class="bi bi-box-arrow-up-right me-1"></i>Abrir no DOERJ
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
<script>
const allSectionsCheckbox = document.getElementById('all-sections');
const sectionInputs = [...document.querySelectorAll('.section-option')];
const sectionsWrap = document.getElementById('section-options');
const highlightTerms = <%- JSON.stringify(highlightTerms || []) %>;
const searchResultModalElement = document.getElementById('searchResultModal');
const searchResultModal = searchResultModalElement ? new bootstrap.Modal(searchResultModalElement) : null;

function syncSectionState() {
  if (allSectionsCheckbox.checked) {
    sectionInputs.forEach(input => {
      input.checked = false;
      input.disabled = true;
    });
    sectionsWrap.classList.add('is-disabled');
    return;
  }

  sectionInputs.forEach(input => { input.disabled = false; });
  sectionsWrap.classList.remove('is-disabled');
}

allSectionsCheckbox.addEventListener('change', syncSectionState);
sectionInputs.forEach(input => {
  input.addEventListener('change', () => {
    const anyChecked = sectionInputs.some(item => item.checked);
    allSectionsCheckbox.checked = !anyChecked;
    syncSectionState();
  });
});

syncSectionState();

function escapeHtml(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeRegex(value) {
  return String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function highlightText(text, terms) {
  const source = String(text || '');
  if (!source) return '-';
  if (!terms.length) return escapeHtml(source);

  const pattern = new RegExp(`(${terms.map(escapeRegex).join('|')})`, 'gi');
  let highlighted = '';
  let lastIndex = 0;

  for (const match of source.matchAll(pattern)) {
    const index = typeof match.index === 'number' ? match.index : -1;
    if (index < 0) continue;

    highlighted += escapeHtml(source.slice(lastIndex, index));
    highlighted += `<mark class="term-highlight">${escapeHtml(match[0])}</mark>`;
    lastIndex = index + match[0].length;
  }

  highlighted += escapeHtml(source.slice(lastIndex));
  return highlighted;
}

document.querySelectorAll('.search-result-row').forEach(row => {
  function shouldIgnore(target) {
    return !!target.closest('a, button, [data-row-ignore="true"]');
  }

  function openResumo() {
    if (!searchResultModal) return;

    const sourceUrl = decodeURIComponent(row.dataset.sourceUrl || '');
    const viewerUrl = decodeURIComponent(row.dataset.viewerUrl || '');
    const resumo = decodeURIComponent(row.dataset.resumo || '');

    document.getElementById('search-modal-data').textContent = row.dataset.data || '-';
    document.getElementById('search-modal-id').textContent = row.dataset.id || '-';
    document.getElementById('search-modal-pagina').textContent = row.dataset.pagina || '-';
    document.getElementById('search-modal-jornal').textContent = decodeURIComponent(row.dataset.jornal || '-') || '-';
    document.getElementById('search-modal-tipo').textContent = decodeURIComponent(row.dataset.tipo || '-') || '-';
    document.getElementById('search-modal-resumo').innerHTML = highlightText(resumo, highlightTerms);

    const openButton = document.getElementById('search-modal-open');
    const viewerButton = document.getElementById('search-modal-viewer');
    if (sourceUrl) {
      openButton.href = sourceUrl;
      openButton.classList.remove('disabled');
      openButton.setAttribute('aria-disabled', 'false');
    } else {
      openButton.href = '#';
      openButton.classList.add('disabled');
      openButton.setAttribute('aria-disabled', 'true');
    }

    if (viewerUrl) {
      viewerButton.href = viewerUrl;
      viewerButton.classList.remove('disabled');
      viewerButton.setAttribute('aria-disabled', 'false');
    } else {
      viewerButton.href = '#';
      viewerButton.classList.add('disabled');
      viewerButton.setAttribute('aria-disabled', 'true');
    }

    searchResultModal.show();
  }

  row.addEventListener('click', event => {
    if (shouldIgnore(event.target)) return;
    openResumo();
  });

  row.addEventListener('keydown', event => {
    if (event.key !== 'Enter' && event.key !== ' ') return;
    event.preventDefault();
    openResumo();
  });
});

document.getElementById('formBusca').addEventListener('submit', function (event) {
  const keyword = this.querySelector('input[name="keyword"]').value.trim();
  const specificSections = sectionInputs.filter(input => input.checked).length;

  if (!keyword && !specificSections) {
    event.preventDefault();
    Swal.fire({
      icon: 'warning',
      title: 'Falta informar a busca',
      text: 'Digite uma palavra-chave ou selecione ao menos uma secao especifica.'
    });
    return;
  }

  const btn = document.getElementById('btnBuscar');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

  Swal.fire({
    title: 'Buscando no DOERJ...',
    text: 'Isso pode levar ate 30 segundos.',
    allowOutsideClick: false,
    showConfirmButton: false,
    didOpen: () => Swal.showLoading()
  });
});
</script>
